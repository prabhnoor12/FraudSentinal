{
  "info": {
    "name": "FraudSentinal API v1",
    "_postman_id": "8aa4b2c2-9026-4d1c-b0f8-b9b7f4d74900",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "jwtToken", "value": "" },
    { "key": "apiKey", "value": "" },
    { "key": "serviceAccountId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"StrongPass123!\",\n  \"organisation_name\": \"Acme\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/api/v1/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"StrongPass123!\"\n}"
        }
      }
    },
    {
      "name": "Service Accounts - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/auth/service-accounts",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"organisation_id\": 1,\n  \"name\": \"fraud-worker\",\n  \"description\": \"Ingestion worker\",\n  \"scopes\": [\"fraud:check\", \"transactions:write\", \"transactions:read\"]\n}"
        }
      }
    },
    {
      "name": "API Keys - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": "{{baseUrl}}/api/v1/auth/service-accounts/{{serviceAccountId}}/keys",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"primary\",\n  \"scopes\": [\"fraud:check\", \"transactions:write\", \"transactions:read\"]\n}"
        }
      }
    },
    {
      "name": "Fraud Check - Submit",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{apiKey}}" },
          { "key": "Idempotency-Key", "value": "fraud-check-demo-001" }
        ],
        "url": "{{baseUrl}}/api/v1/check-fraud",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": 1,\n  \"organisation_id\": 1,\n  \"amount\": 149.95,\n  \"currency\": \"USD\",\n  \"payment_method\": \"card\",\n  \"channel\": \"api\",\n  \"customer_id\": \"cust_001\",\n  \"metadata\": {\"source\": \"postman\"}\n}"
        }
      }
    },
    {
      "name": "Transactions - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{apiKey}}" },
          { "key": "Idempotency-Key", "value": "transaction-demo-001" }
        ],
        "url": "{{baseUrl}}/api/v1/transactions",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": 1,\n  \"organisation_id\": 1,\n  \"amount\": 49.50,\n  \"currency\": \"USD\",\n  \"payment_method\": \"card\",\n  \"channel\": \"api\",\n  \"customer_id\": \"cust_002\",\n  \"metadata\": {\"source\": \"postman\"}\n}"
        }
      }
    },
    {
      "name": "Billing Records - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-API-Key", "value": "{{apiKey}}" },
          { "key": "Idempotency-Key", "value": "billing-demo-001" }
        ],
        "url": "{{baseUrl}}/api/v1/billing/records",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": 1,\n  \"organisation_id\": 1,\n  \"amount\": 25.0,\n  \"currency\": \"USD\",\n  \"status\": \"pending\",\n  \"invoice_id\": \"inv_postman_001\",\n  \"description\": \"Demo billing record\",\n  \"billing_period_start\": \"2026-07-01T00:00:00Z\",\n  \"billing_period_end\": \"2026-07-31T23:59:59Z\"\n}"
        }
      }
    }
  ]
}
